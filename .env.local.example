# ── Firebase (Client SDK) ────────────────────────────────────────
# Find these in Firebase Console → Project Settings → General → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional: Realtime Database
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# ── Firebase Admin SDK (Server-side only) ────────────────────────
# Option A: Base64-encoded service account JSON
#   openssl base64 -in serviceAccountKey.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_KEY=

# Option B: Individual fields (if base64 not available)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Stripe ───────────────────────────────────────────────────────
# Find in Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Webhook signing secret — register /api/webhooks/stripe in Stripe Dashboard
# Events: checkout.session.completed, customer.subscription.deleted, invoice.payment_succeeded
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the Pro monthly plan (€4.99/month)
# Create in Stripe Dashboard → Products → Add product → Add price
STRIPE_PRICE_ID_PRO=price_1TCbrBBFWQGmBUmWLBW9gBeg
# Minimum payout amount in cents (default: 500 = €5.00)
NEXT_PUBLIC_MIN_PAYOUT_CENTS=500

# ── Google TTS (Voice fallback) ──────────────────────────────────
# Cloud Text-to-Speech API key (optional: falls back to Web Speech API)
GOOGLE_TTS_API_KEY=

# ── Anthropic (Claude Haiku — city search AI) ────────────────────
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── App URL ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://wanderquest.app
