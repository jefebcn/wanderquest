rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isPro() {
      return isSignedIn() && request.auth.token.tier == "pro";
    }

    // ── Landmarks (read-only for public, write only for admins) ─────────────
    match /landmarks/{landmarkId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Users ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Public profile fields are readable by anyone
      allow read: if true;
      // Only the owner can write their own profile
      // but they CANNOT modify totalPoints (managed by Cloud Functions)
      allow update: if isOwner(userId)
        && !("totalPoints" in request.resource.data.diff(resource.data).affectedKeys());
      allow create: if isOwner(userId);
      allow delete: if false;
    }

    // ── Visits ───────────────────────────────────────────────────────────────
    match /visits/{visitId} {
      // User can read their own visits
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Only Cloud Functions (admin SDK) can create/update visits
      allow write: if false;
    }

    // ── Contests ─────────────────────────────────────────────────────────────
    match /contests/{contestId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Leaderboard (denormalised, updated by Cloud Functions) ───────────────
    match /leaderboard/{contestId}/entries/{userId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Wallets ───────────────────────────────────────────────────────────────
    match /wallets/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if false; // Cloud Functions only
    }

    // ── Withdrawal Requests ───────────────────────────────────────────────────
    match /withdrawals/{withdrawalId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      // Users can create withdrawal requests; updates are by Cloud Functions
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.status == "pending";
      allow update: if false;
    }

    // ── Partners (B2B coupon hub) ─────────────────────────────────────────────
    match /partners/{partnerId} {
      // Free coupons: public read. Pro-only coupons: require Pro claim.
      allow read: if !resource.data.isProOnly || isPro() || isAdmin();
      allow write: if isAdmin();
    }

    match /partners/{partnerId}/coupons/{couponId} {
      allow read: if !resource.data.isProOnly || isPro() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Manual subscription reviews (write-once by owner) ────────────────────
    match /manual_subscription_reviews/{reviewId} {
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Elite Landmarks (Pro-only sub-collection) ────────────────────────────
    match /elite_landmarks/{landmarkId} {
      allow read: if isPro() || isAdmin();
      allow write: if isAdmin();
    }

    // ── Meta (active contest pointer, app-wide config) ───────────────────────
    match /meta/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Contest photos ───────────────────────────────────────────────────────
    match /contest_photos/{photoId} {
      // Anyone signed-in can read; writes go through server actions (admin SDK)
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── Contest votes ────────────────────────────────────────────────────────
    match /contest_votes/{voteId} {
      allow read: if isSignedIn() && resource.data.voterId == request.auth.uid;
      allow write: if false;
    }

    // ── Contest photo views ──────────────────────────────────────────────────
    match /contest_photo_views/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ── Contest leaderboard ──────────────────────────────────────────────────
    match /contest_leaderboard/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ── Packing Lists (Smart Pack Agent) ─────────────────────────────────────
    // One document per user, keyed by uid. Owner full CRUD; others cannot read.
    match /packing_lists/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Gear Posts (Social Feed from Smart Pack Agent) ────────────────────────
    // Any signed-in user can create; owner can delete; signed-in can read.
    match /gear_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

  }
}
